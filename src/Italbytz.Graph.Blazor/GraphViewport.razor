@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="graph-viewport-shell" @ref="_host">
    <div class="graph-viewport-toolbar">
        <div class="graph-viewport-actions">
            <button class="btn btn-outline-primary btn-sm" type="button" @onclick="ZoomOutAsync">@ZoomOutLabel</button>
            <button class="btn btn-outline-primary btn-sm" type="button" @onclick="ZoomInAsync">@ZoomInLabel</button>
            <button class="btn btn-primary btn-sm" type="button" @onclick="FitAsync">@FitLabel</button>
            <button class="btn btn-link btn-sm" type="button" @onclick="ResetAsync">@ResetLabel</button>
        </div>

        <p class="graph-viewport-hint">@InteractionHint</p>
    </div>

    <div class="graph-viewport-status" aria-live="polite">
        <span class="graph-status-pill graph-status-pill-current">@CurrentNodeLegendLabel: @CurrentNodeDisplayLabel</span>
        <span class="graph-status-pill graph-status-pill-frontier">@FrontierLegendLabel: @FrontierNodeSet.Count</span>
        <span class="graph-status-pill graph-status-pill-explored">@ExploredLegendLabel: @ExploredNodeSet.Count</span>
        <span class="graph-status-pill graph-status-pill-active">@ActiveLegendLabel: @ActiveEdgeSet.Count</span>
        <span class="graph-status-pill graph-status-pill-successor">@SuccessorLegendLabel: @SuccessorEdgeSet.Count</span>
    </div>

    <div class="graph-viewport-stage" data-graph-stage tabindex="0">
        <svg class="graph-viewport-svg"
             viewBox="0 0 @Svg(Graph.ViewBoxWidth) @Svg(Graph.ViewBoxHeight)"
             preserveAspectRatio="xMidYMid meet"
             role="img"
             aria-label="@Title"
             @onclick="ClearSelection">
            <defs>
                <pattern id="gridPattern" width="24" height="24" patternUnits="userSpaceOnUse">
                    <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(148, 163, 184, 0.12)" stroke-width="1"></path>
                </pattern>
                <marker id="graphArrow" markerWidth="12" markerHeight="12" refX="10" refY="6" orient="auto" markerUnits="userSpaceOnUse">
                    <path d="M 0 0 L 12 6 L 0 12 z" fill="context-stroke"></path>
                </marker>
                <filter id="nodeShadow" x="-20%" y="-20%" width="140%" height="140%">
                    <feDropShadow dx="0" dy="8" stdDeviation="10" flood-color="rgba(15, 23, 42, 0.14)"></feDropShadow>
                </filter>
            </defs>

            <rect class="graph-viewport-background" x="0" y="0" width="100%" height="100%" fill="url(#gridPattern)"></rect>

            <g class="graph-viewport-content" data-graph-viewport>
                @foreach (var edge in Graph.Edges)
                {
                    <g class="@GetEdgeCss(edge)" @onclick:stopPropagation @onclick="() => SelectEdge(edge.EdgeKey)">
                        <path class="graph-edge-path"
                              d="@edge.PathData"
                              marker-start="@GetEdgeMarkerStart(edge)"
                              marker-end="@GetEdgeMarkerEnd(edge)"></path>
                        <g class="graph-edge-label">
                            <rect x="@Svg(edge.LabelX - 16)" y="@Svg(edge.LabelY - 12)" width="32" height="24" rx="12"></rect>
                            <text x="@Svg(edge.LabelX)" y="@Svg(edge.LabelY)">@edge.Weight</text>
                            <title>@GetEdgeTitle(edge)</title>
                        </g>
                    </g>
                }

                @foreach (var node in Graph.Nodes)
                {
                    <g class="@GetNodeCss(node)" @onclick:stopPropagation @onclick="() => SelectNode(node.Id)">
                        <ellipse class="graph-node-shape"
                                 cx="@Svg(node.CenterX)"
                                 cy="@Svg(node.CenterY)"
                                 rx="@Svg(node.RadiusX)"
                                 ry="@Svg(node.RadiusY)"></ellipse>
                        <text class="graph-node-text" x="@Svg(node.CenterX)" y="@Svg(node.CenterY)">@node.Label</text>
                        <title>@GetNodeTitle(node)</title>
                    </g>
                }
            </g>
        </svg>
    </div>

    <div class="graph-viewport-footer">
        <div class="graph-viewport-legend">
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-active"></span>@ActiveLegendLabel</span>
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-successor"></span>@SuccessorLegendLabel</span>
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-current"></span>@CurrentNodeLegendLabel</span>
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-frontier"></span>@FrontierLegendLabel</span>
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-explored"></span>@ExploredLegendLabel</span>
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-solution"></span>@SolutionLegendLabel</span>
            <span class="graph-legend-item"><span class="graph-legend-swatch graph-legend-swatch-default"></span>@DefaultLegendLabel</span>
        </div>

        <aside class="graph-viewport-inspector">
            <p class="feature-card-kicker">@InspectorTitle</p>

            @if (SelectedNode is not null)
            {
                <h3>@SelectedNode.Label</h3>
                <p>@NodeInspectorText</p>
            }
            else if (SelectedEdge is not null)
            {
                <h3>@SelectedEdge.Source - @SelectedEdge.Target</h3>
                <p>@EdgeInspectorText</p>
            }
            else
            {
                <h3>@NoSelectionTitle</h3>
                <p>@NoSelectionText</p>
            }
        </aside>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public GraphViewModel Graph { get; set; } = default!;

    [Parameter]
    public IReadOnlyCollection<string> ActiveEdgeKeys { get; set; } = Array.Empty<string>();

    [Parameter]
    public IReadOnlyCollection<string> ActiveNodeKeys { get; set; } = Array.Empty<string>();

    [Parameter]
    public IReadOnlyCollection<string> FrontierNodeKeys { get; set; } = Array.Empty<string>();

    [Parameter]
    public IReadOnlyCollection<string> ExploredNodeKeys { get; set; } = Array.Empty<string>();

    [Parameter]
    public string? CurrentNodeKey { get; set; }

    [Parameter]
    public IReadOnlyCollection<string> SuccessorEdgeKeys { get; set; } = Array.Empty<string>();

    [Parameter]
    public IReadOnlyCollection<string> DirectedActiveEdgeIds { get; set; } = Array.Empty<string>();

    [Parameter]
    public IReadOnlyCollection<string> DirectedSuccessorEdgeIds { get; set; } = Array.Empty<string>();

    [Parameter]
    public string Title { get; set; } = "Graph";

    [Parameter]
    public string ZoomInLabel { get; set; } = "+";

    [Parameter]
    public string ZoomOutLabel { get; set; } = "-";

    [Parameter]
    public string FitLabel { get; set; } = "Fit";

    [Parameter]
    public string ResetLabel { get; set; } = "Reset";

    [Parameter]
    public string InteractionHint { get; set; } = string.Empty;

    [Parameter]
    public string ActiveLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string SuccessorLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string CurrentNodeLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string FrontierLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string ExploredLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string SolutionLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string DefaultLegendLabel { get; set; } = string.Empty;

    [Parameter]
    public string InspectorTitle { get; set; } = string.Empty;

    [Parameter]
    public string NoSelectionTitle { get; set; } = string.Empty;

    [Parameter]
    public string NoSelectionText { get; set; } = string.Empty;

    [Parameter]
    public string NodeLabel { get; set; } = string.Empty;

    [Parameter]
    public string EdgeLabel { get; set; } = string.Empty;

    [Parameter]
    public string WeightLabel { get; set; } = string.Empty;

    [Parameter]
    public string ConnectionsLabel { get; set; } = string.Empty;

    [Parameter]
    public string StateLabel { get; set; } = string.Empty;

    private readonly StringComparer _comparer = StringComparer.Ordinal;
    private ElementReference _host;
    private IJSObjectReference? _module;
    private string? _selectedNodeId;
    private string? _selectedEdgeKey;

    private HashSet<string> ActiveEdgeSet => [.. ActiveEdgeKeys];

    private HashSet<string> ActiveNodeSet => [.. ActiveNodeKeys];

    private HashSet<string> FrontierNodeSet => [.. FrontierNodeKeys];

    private HashSet<string> ExploredNodeSet => [.. ExploredNodeKeys];

    private HashSet<string> SuccessorEdgeSet => [.. SuccessorEdgeKeys];

    private HashSet<string> DirectedActiveEdgeSet => [.. DirectedActiveEdgeIds];

    private HashSet<string> DirectedSuccessorEdgeSet => [.. DirectedSuccessorEdgeIds];

    private GraphNodeViewModel? SelectedNode => _selectedNodeId is null
        ? null
        : Graph.Nodes.FirstOrDefault(node => _comparer.Equals(node.Id, _selectedNodeId));

    private GraphEdgeViewModel? SelectedEdge => _selectedEdgeKey is null
        ? null
        : Graph.Edges.FirstOrDefault(edge => _comparer.Equals(edge.EdgeKey, _selectedEdgeKey));

    private string CurrentNodeDisplayLabel => string.IsNullOrWhiteSpace(CurrentNodeKey)
        ? "-"
        : Graph.Nodes.FirstOrDefault(node => _comparer.Equals(node.Id, CurrentNodeKey))?.Label ?? CurrentNodeKey;

    private string NodeInspectorText => SelectedNode is null
        ? string.Empty
        : $"{NodeLabel}: {SelectedNode.Label} · {StateLabel}: {GetNodeStateText(SelectedNode)} · {ConnectionsLabel}: {Graph.Edges.Count(edge => _comparer.Equals(edge.Source, SelectedNode.Id) || _comparer.Equals(edge.Target, SelectedNode.Id))}";

    private string EdgeInspectorText => SelectedEdge is null
        ? string.Empty
        : $"{EdgeLabel}: {SelectedEdge.Source} - {SelectedEdge.Target} · {WeightLabel}: {SelectedEdge.Weight} · {StateLabel}: {GetEdgeStateText(SelectedEdge)}";

    protected override void OnParametersSet()
    {
        if (_selectedNodeId is not null && Graph.Nodes.All(node => !_comparer.Equals(node.Id, _selectedNodeId)))
        {
            _selectedNodeId = null;
        }

        if (_selectedEdgeKey is not null && Graph.Edges.All(edge => !_comparer.Equals(edge.EdgeKey, _selectedEdgeKey)))
        {
            _selectedEdgeKey = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Italbytz.Graph.Blazor/GraphViewport.razor.js");
            await _module.InvokeVoidAsync("initialize", _host);
        }

        if (_module is not null)
        {
            await _module.InvokeVoidAsync("refresh", _host);
        }
    }

    private Task ZoomInAsync() => InvokeViewportAsync("zoomIn");

    private Task ZoomOutAsync() => InvokeViewportAsync("zoomOut");

    private Task FitAsync() => InvokeViewportAsync("fit");

    private Task ResetAsync() => InvokeViewportAsync("reset");

    private async Task InvokeViewportAsync(string method)
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync(method, _host);
        }
    }

    private void SelectNode(string nodeId)
    {
        _selectedNodeId = nodeId;
        _selectedEdgeKey = null;
    }

    private void SelectEdge(string edgeKey)
    {
        _selectedEdgeKey = edgeKey;
        _selectedNodeId = null;
    }

    private void ClearSelection()
    {
        _selectedNodeId = null;
        _selectedEdgeKey = null;
    }

    private string Svg(double value) => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private string GetNodeCss(GraphNodeViewModel node)
    {
        var cssClass = "graph-node";
        if (_comparer.Equals(CurrentNodeKey, node.Id))
        {
            cssClass += " graph-node-current";
        }
        else if (FrontierNodeSet.Contains(node.Id))
        {
            cssClass += " graph-node-frontier";
        }
        else if (ActiveNodeSet.Contains(node.Id))
        {
            cssClass += " graph-node-active";
        }
        else if (ExploredNodeSet.Contains(node.Id))
        {
            cssClass += " graph-node-explored";
        }
        else if (node.IsPartOfSolution)
        {
            cssClass += " graph-node-solution";
        }

        if (_comparer.Equals(_selectedNodeId, node.Id))
        {
            cssClass += " graph-node-selected";
        }

        return cssClass;
    }

    private string GetEdgeCss(GraphEdgeViewModel edge)
    {
        var cssClass = "graph-edge";
        if (ActiveEdgeSet.Contains(edge.EdgeKey))
        {
            cssClass += " graph-edge-active";
        }
        else if (SuccessorEdgeSet.Contains(edge.EdgeKey))
        {
            cssClass += " graph-edge-successor";
        }
        else if (edge.IsPartOfSolution)
        {
            cssClass += " graph-edge-solution";
        }

        if (_comparer.Equals(_selectedEdgeKey, edge.EdgeKey))
        {
            cssClass += " graph-edge-selected";
        }

        return cssClass;
    }

    private string GetNodeTitle(GraphNodeViewModel node)
        => $"{NodeLabel}: {node.Label} ({StateLabel}: {GetNodeStateText(node)})";

    private string GetEdgeTitle(GraphEdgeViewModel edge)
        => $"{edge.Source} - {edge.Target} ({WeightLabel}: {edge.Weight}, {StateLabel}: {GetEdgeStateText(edge)})";

    private string GetNodeStateText(GraphNodeViewModel node)
    {
        if (_comparer.Equals(CurrentNodeKey, node.Id))
        {
            return CurrentNodeLegendLabel;
        }

        if (FrontierNodeSet.Contains(node.Id))
        {
            return FrontierLegendLabel;
        }

        if (ExploredNodeSet.Contains(node.Id))
        {
            return ExploredLegendLabel;
        }

        if (ActiveNodeSet.Contains(node.Id))
        {
            return ActiveLegendLabel;
        }

        if (node.IsPartOfSolution)
        {
            return SolutionLegendLabel;
        }

        return DefaultLegendLabel;
    }

    private string GetEdgeStateText(GraphEdgeViewModel edge)
    {
        if (ActiveEdgeSet.Contains(edge.EdgeKey))
        {
            return ActiveLegendLabel;
        }

        if (SuccessorEdgeSet.Contains(edge.EdgeKey))
        {
            return SuccessorLegendLabel;
        }

        if (edge.IsPartOfSolution)
        {
            return SolutionLegendLabel;
        }

        return DefaultLegendLabel;
    }

    private string? GetEdgeMarkerStart(GraphEdgeViewModel edge)
    {
        var reverseDirectionId = $"{edge.Target}>{edge.Source}";
        if (DirectedActiveEdgeSet.Contains(reverseDirectionId) || DirectedSuccessorEdgeSet.Contains(reverseDirectionId))
        {
            return "url(#graphArrow)";
        }

        return null;
    }

    private string? GetEdgeMarkerEnd(GraphEdgeViewModel edge)
    {
        var forwardDirectionId = $"{edge.Source}>{edge.Target}";
        if (DirectedActiveEdgeSet.Contains(forwardDirectionId) || DirectedSuccessorEdgeSet.Contains(forwardDirectionId))
        {
            return "url(#graphArrow)";
        }

        return null;
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _host);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}